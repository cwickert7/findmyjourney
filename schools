.page-body{max-width:840px;margin:0 auto;padding:64px 48px 96px}
.page-updated{font-size:12px;color:var(--lt);margin-bottom:48px;padding-bottom:16px;border-bottom:1px solid var(--sand)}
.page-section{margin-bottom:48px}
.page-section h2{font-family:"Fraunces",serif;font-size:26px;font-weight:400;color:var(--ch);margin-bottom:14px;margin-top:40px}
.page-section h3{font-size:16px;font-weight:600;color:var(--ch);margin-bottom:8px;margin-top:24px}
.page-section p{font-size:15px;color:var(--mid);line-height:1.8;margin-bottom:14px}
.page-section ul{padding-left:20px;margin-bottom:14px}
.page-section li{font-size:15px;color:var(--mid);line-height:1.8;margin-bottom:6px}
.page-section a{color:var(--tc);text-decoration:underline}
.highlight-box{background:#fff;border:1.5px solid var(--sand);border-radius:12px;padding:24px 28px;margin:24px 0}
.highlight-box p{margin-bottom:0}
.contact-field{margin-bottom:20px}
.contact-field label{display:block;font-size:13px;font-weight:600;color:var(--ch);margin-bottom:6px;letter-spacing:.03em}
.contact-field input,.contact-field textarea,.contact-field select{width:100%;border:1.5px solid var(--sand);border-radius:10px;padding:12px 16px;font-size:15px;font-family:"DM Sans",sans-serif;color:var(--ch);background:var(--warm);outline:none;transition:border-color .2s}
.contact-field input:focus,.contact-field textarea:focus,.contact-field select:focus{border-color:var(--tc)}
.contact-field textarea{min-height:140px;resize:vertical}
.contact-submit{background:var(--tc);color:#fff;border:none;border-radius:50px;padding:15px 36px;font-size:16px;font-weight:600;cursor:pointer;font-family:"DM Sans",sans-serif;transition:background .2s}
.contact-submit:hover{background:var(--tcd)}
.info-card{background:#fff;border:1.5px solid var(--sand);border-radius:12px;padding:24px;margin-bottom:16px}
.info-card-icon{font-size:28px;margin-bottom:10px}
.info-card-title{font-size:16px;font-weight:600;color:var(--ch);margin-bottom:6px}
.info-card-desc{font-size:14px;color:var(--mid);line-height:1.65}
footer{background:#1E1613;padding:40px 48px 28px}
