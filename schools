.nav-ring{width:30px;height:30px;border:2px solid var(--tc);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--tc);animation:spin 14s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.nav-name{font-family:"Fraunces",serif;font-size:15px;letter-spacing:.05em;color:var(--ch)}
.nav-cta{background:var(--tc);color:#fff;border:none;border-radius:50px;padding:10px 24px;font-size:14px;font-weight:600;cursor:pointer;font-family:"DM Sans",sans-serif;text-decoration:none;transition:background .2s}
.nav-cta:hover{background:var(--tcd)}
.page-hero{background:var(--ch);padding:120px 48px 64px;text-align:center}
.page-eyebrow{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--tc);margin-bottom:16px}
.page-h1{font-family:"Fraunces",serif;font-size:clamp(40px,5vw,68px);font-weight:300;color:#fff;line-height:1.05;margin-bottom:16px}
.page-h1 em{font-style:italic;color:var(--tcl)}
